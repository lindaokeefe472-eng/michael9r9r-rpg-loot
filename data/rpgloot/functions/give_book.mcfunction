give @a written_book[written_book_content={title:"RPG Loot \u73a9\u5bb6\u6307\u5357",author:"michael9r9r",pages:['{"text": "\u2694\ufe0f RPG Loot \u73a9\u6cd5\u6307\u5357\n\n\u6b22\u8fce\u6765\u5230 RPG Loot \u4e16\u754c\uff01\n\u672c\u6570\u636e\u5305\u4e3a\u5168\u754c\u6dfb\u52a0\u4e86\u7b49\u7ea7\u602a\u7269\u3001\u968f\u673a\u54c1\u8d28\u6218\u5229\u54c1\u4e0e\u526f\u672c\u9057\u8ff9\u3002\n\n\u25b6 \u7ffb\u9875\u67e5\u770b\u8be6\u7ec6\u673a\u5236", "color": "dark_green", "bold": true}','{"text": "\ud83d\udc79 \u602a\u7269\u7b49\u7ea7\u673a\u5236\n\n\u666e\u901a\u602a\u7269\u751f\u6210\u65f6\u6709\u6982\u7387\u8fdb\u5316\u4e3a RPG \u7cbe\u82f1\uff1a\n\ud83d\udfe2 Veteran (\u8001\u5175)\n\ud83d\udd35 Elite (\u7cbe\u82f1)\n\ud83d\udfe3 Champion (\u52c7\u58eb)\n\ud83d\udfe1 Legendary (\u4f20\u8bf4)\n\ud83d\udd34 Unique (\u72ec\u7279Boss)", "color": "dark_purple"}','{"text": "\ud83d\udde1\ufe0f \u88c5\u5907\u54c1\u8d28\u9636\u68af\n\n\u51fb\u6740 Boss \u6216\u5f00\u542f\u9057\u8ff9\u5b9d\u7bb1\u53ef\u83b7\u5f97\uff1a\n\u2022 Uncommon (\u666e\u901a)\n\u2022 Rare (\u7a00\u6709)\n\u2022 Very Rare (\u53f2\u8bd7)\n\u2022 Legendary (\u4f20\u8bf4)\n\u5177\u6709\u968f\u673a\u9ad8\u9636\u9644\u9b54\u4e0e\u5c5e\u6027\u52a0\u6210\uff01", "color": "gold"}','{"text": "\u2699\ufe0f \u5feb\u6377\u6307\u4ee4\u4e0e\u8bbe\u7f6e\n\n\u5728\u804a\u5929\u680f\u70b9\u51fb\u4ee5\u4e0b\u94fe\u63a5\uff1a\n\n[\u2699\ufe0f \u6253\u5f00\u8bbe\u7f6e\u83dc\u5355]\n[\ud83d\udcca \u67e5\u770b\u89d2\u8272\u5c5e\u6027]\n[\ud83c\udff0 \u751f\u6210\u968f\u673a\u526f\u672c]", "color": "dark_blue"}']}]
